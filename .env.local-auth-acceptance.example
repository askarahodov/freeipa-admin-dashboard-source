# Target a running local portal. The acceptance runner never runs in GitHub Actions.
PORTAL_TEST_BASE_URL=http://127.0.0.1:3001

# Explicit confirmation is required because the runner creates and deletes
# temporary internal portal users.
PORTAL_TEST_CONFIRM=YES

# Existing local administrator used only for the duration of the run.
PORTAL_TEST_ADMIN_USERNAME=admin
PORTAL_TEST_ADMIN_PASSWORD=replace-with-the-current-local-admin-password

# Per-request timeout, 1-120 seconds.
PORTAL_TEST_TIMEOUT_MS=15000
