# Copy to .env.test. This profile is for an isolated local test environment only.
ADMIN_TOKEN=replace-with-a-long-random-test-admin-token
CONFIG_ENCRYPTION_KEY=1d787ea814fe48eb077f436970167c890f6c0ca737557b17e00252c27595ce71
DEMO_MODE=false

# Static identity is acceptable only for this isolated local test container.
PORTAL_IDENTITY_MODE=static
PORTAL_STATIC_IDENTITY=portal-test-admin@example.test
PORTAL_DEFAULT_ROLE=viewer
PORTAL_RBAC_JSON={"portal-test-admin@example.test":"admin"}

# Real test FreeIPA instance and dedicated service account.
IPA_URL=https://ipa-test.company.local
IPA_USERNAME=portal-test-manager
IPA_PASSWORD=change-me
IPA_VERIFY_TLS=true

# Real test XYOps instance and dedicated API key.
XYOPS_URL=http://127.0.0.1:8080
XYOPS_API_KEY=change-me
XYOPS_CATALOG_SYNC_ENABLED=false

# Local test runner.
LOCAL_TEST_BASE_URL=http://127.0.0.1:3001
LOCAL_TEST_ARTIFACT_DIR=artifacts/local-integration
LOCAL_TEST_REQUEST_TIMEOUT_MS=20000
LOCAL_TEST_PREFIX=portal-test
LOCAL_TEST_KEEP_RUNNING=false

# Safe default: read-only checks only.
LOCAL_TEST_MUTATIONS=false
LOCAL_TEST_CONFIRM_MUTATIONS=NO
LOCAL_TEST_FREEIPA_MUTATIONS=false
LOCAL_TEST_XYOPS_RUN=false

# To test a dedicated non-dangerous XYOps process, enable both mutation flags and
# provide its exact process ID and values. Never point this at production.
LOCAL_TEST_XYOPS_EVENT_ID=
LOCAL_TEST_XYOPS_VALUES_JSON={}
LOCAL_TEST_XYOPS_TARGETS_JSON=[]
LOCAL_TEST_XYOPS_WAIT_TERMINAL=false
LOCAL_TEST_XYOPS_POLL_SECONDS=60

# Optional dynamic-options smoke check.
LOCAL_TEST_OPTIONS_EVENT_ID=
LOCAL_TEST_OPTIONS_FIELD_KEY=
LOCAL_TEST_OPTIONS_QUERY=
