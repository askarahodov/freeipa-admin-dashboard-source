DASHBOARD_PORT=3000

# Admin access for persistent configuration endpoints
ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Public development-only key. Keep it stable for the local test database,
# but replace it before any production or shared deployment.
CONFIG_ENCRYPTION_KEY=d0ee92e4c9b6b9e1282d4808ff08e03de28087b1b0b3b5f44198f7bdbe782ec5

# Run in demo mode without external integrations
DEMO_MODE=false

# Identity modes:
# - anonymous: safe default; every request is read-only viewer
# - static: isolated local development only; all requests use one server identity
# - workspace: trust OpenAI Sites oai-authenticated-user-* headers
# - proxy: trust reverse-proxy identity headers only with the shared secret
PORTAL_IDENTITY_MODE=static
PORTAL_STATIC_IDENTITY=admin@company.local

# Roles: viewer (read-only), operator (FreeIPA changes + XYOps launches),
# admin (all actions, deletions and settings). Missing/anonymous identities are
# always viewer even if a legacy wildcard assignment grants a wider role.
PORTAL_DEFAULT_ROLE=viewer
PORTAL_RBAC_JSON={"admin@company.local":"admin","ops@company.local":"operator","audit@company.local":"viewer"}

# Reverse-proxy production example. The proxy must delete client-supplied
# identity/secret headers and inject its own values after authentication.
# PORTAL_IDENTITY_MODE=proxy
# PORTAL_IDENTITY_HEADER=x-auth-request-email
# PORTAL_IDENTITY_NAME_HEADER=x-auth-request-user
# PORTAL_PROXY_SECRET_HEADER=x-portal-proxy-secret
# PORTAL_PROXY_SHARED_SECRET=replace-with-a-long-random-proxy-secret

# FreeIPA is an independent management module. Use a dedicated service account
# with only the user/group permissions that the portal must expose.
IPA_URL=https://ipa.company.local
IPA_USERNAME=portal-freeipa-manager
IPA_PASSWORD=change-me
IPA_VERIFY_TLS=true

# XYOps is optional for basic FreeIPA administration and orchestrates only
# additional Events, Workflows and cross-system automation.
XYOPS_URL=https://xyops.company.local
XYOPS_API_KEY=change-me
XYOPS_EVENT_ID=freeipa-user-create

# Maximum declared Content-Length accepted by the output-file proxy (50 MiB).
# Keep a matching response-size limit in the external reverse proxy as well.
XYOPS_RESULT_FILE_MAX_BYTES=52428800

# Cloudflare invokes worker.scheduled() every hour through the configured cron.
# Set false to pause automatic synchronization without removing the trigger.
XYOPS_CATALOG_SYNC_ENABLED=true
XYOPS_CATALOG_SYNC_LOCK_TTL_SECONDS=900

# Array of server-side routing profiles. Keep the JSON on one line.
XYOPS_ROUTES_JSON=[{"key":"user-create","title":"Создание пользователя","operation":"user_add","kind":"event","eventId":"freeipa-user-create","enabled":true,"targets":[],"fields":[{"key":"username","label":"Логин","type":"string","required":true,"target":"params"},{"key":"firstName","label":"Имя","type":"string","required":true,"target":"params"},{"key":"lastName","label":"Фамилия","type":"string","required":true,"target":"params"},{"key":"email","label":"Email","type":"string","target":"params"}]},{"key":"user-onboarding","title":"Полный onboarding","operation":"user_add","kind":"workflow","eventId":"freeipa-user-onboarding","enabled":true,"targets":[],"fields":[{"key":"username","label":"Логин","type":"string","required":true,"target":"params"},{"key":"department","label":"Отдел","type":"select","required":true,"target":"workflowData","options":["development","devops","security"]}]},{"key":"group-create","title":"Создание группы","operation":"group_add","kind":"event","eventId":"freeipa-group-create","enabled":true,"targets":[],"fields":[{"key":"group","label":"Группа","type":"string","required":true,"target":"params"},{"key":"description","label":"Описание","type":"string","target":"params"}]}]


# Catalog visibility policies. The JSON editor in Settings persists an override in D1.
# PORTAL_CATALOG_POLICIES_JSON={"version":1,"defaultEffect":"allow","adminBypass":true,"rules":[]}
# Static identity groups, comma-separated.
# PORTAL_STATIC_GROUPS=ops,dba
# Identity-to-groups mapping for workspace/static/proxy modes.
# PORTAL_GROUPS_JSON={"operator@example.test":["ops"],"*":["employees"]}
# Trusted proxy groups header; accepted only after PORTAL_PROXY_SHARED_SECRET validation.
# PORTAL_GROUPS_HEADER=x-auth-request-groups
